{{> header title="Contact Us | Tigris Mediterranean Grille" description="Have a question or craving? Reach out, visit us, or place an order. We're here to make your experience Fresh, Fast, Fantastic!" pathname="/contact/"}}

{{!-- JSON-LD structured data --}}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Us",
  "description": "Contact page for {{company}}",
  "url": "{{url}}contact",
  "mainEntity": {
    "@type": "Restaurant",
    "name": "{{company}}",
    "url": "{{url}}",
    "telephone": "{{phone}}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{address}}",
      "addressLocality": "{{city}}",
      "addressRegion": "{{state}}",
      "postalCode": "{{zip}}",
      "addressCountry": "US"
    },
    "sameAs": [
      "{{facebook}}",
      "{{instagram}}",
      "{{tiktok}}",
      "{{yelp}}",
      "{{google}}"
    ]
  }
}
</script>


{{!-- reCAPTCHA v3 --}}
<script src="https://www.google.com/recaptcha/api.js?render=6LdzKe0rAAAAAFUuRz7eXzlS65GMXPuIN4MMPsze"></script>

<body>
  {{!-- Navbar --}}
  {{> navbar}}

  <section class="contact-hero curved-image-bottom">
    <div class="contact-hero__overlay"></div>
    <picture class="contact-hero__image">
      <img srcset="{{url}}assets/images/food/menu-flatbread-meat-contact-480.webp 480w,
                   {{url}}assets/images/food/menu-flatbread-meat-contact-640.webp 640w,
                   {{url}}assets/images/food/menu-flatbread-meat-contact-960.webp 960w,
                   {{url}}assets/images/food/menu-flatbread-meat-contact-1280.webp 1280w,
                   {{url}}assets/images/food/menu-flatbread-meat-contact-1920.webp 1920w"
           sizes="100vw"
           src="{{url}}assets/images/food/menu-flatbread-meat-contact-1920.webp"
           alt="Meat flatbread fresh from Tigris Mediterranean Grille"
           width="1920" height="1281" loading="eager" />
    </picture>
  </section>

  {{!-- Restaurant Info --}}
  <div class="container pt-5 mw-100">
    <div class="row d-flex justify-content-center">

      <div class="col-md-6 d-flex flex-column align-items-center mb-4">
        <h3 class="mb-3">Contact Us</h3>
        <div class="contact-form w-100 bg-brand-primary" id="contact-us-form">
          <form class="p-4">
            <input type="hidden" name="recaptcha-token" id="recaptcha-token" />
            <input type="hidden" name="formtype" value="contact-us" />
            <div class="row mb-3">
              <div class="mb-2 col-6 d-flex flex-column">
                <label for="contact-firstname" class="text-white">First Name <span
                    class="required-indicator">*</span></label>
                <input type="text" class="form-control form-input contact-form-input" id="contact-firstname"
                  name="contactfirstname" required>
              </div>
              <div class="mb-2 col-6 d-flex flex-column">
                <label for="contact-lastname" class="text-white">Last Name <span
                    class="required-indicator">*</span></label>
                <input type="text" class="form-control form-input contact-form-input" id="contact-lastname"
                  name="contactlastname" required>
              </div>
            </div>
            <label for="contact-email" class="text-white">Email Address <span class="required-indicator">*</span></label>
            <input type="email" class="mb-3 form-control form-input contact-form-input" id="contact-email"
              name="contactemail" required>
            <label for="contact-phone" class="text-white">Phone <span class="required-indicator">*</span></label>
            <input type="tel" class="mb-3 form-control form-input contact-form-input" id="contact-phone"
              name="contactphone" required>
            <label for="contact-message" class="text-white">Message <span class="required-indicator">*</span></label>
            <textarea class="mb-4 form-control form-input contact-form-input" id="contact-message" rows="4"
              name="contactmessage" required></textarea>
            <button type="submit" class="btn btn-danger w-100">SUBMIT</button>
          </form>
        </div>
        <!-- loading spinner -->
        {{> loading-spinner spinnerText="Submitting your inquiry..."}}
      </div>

      <div class="col-md-6 d-flex flex-column align-items-center mb-4">
        <h3 class="mb-3">Find Us</h3>
        <iframe id="google-map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3352.552689406989!2d-117.13042949999999!3d32.8306151!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80dbffb46eb566e1%3A0x39c5d62b7baaf06!2sTigris%20Mediterranean%20Grille!5e0!3m2!1sen!2sus!4v1760667174062!5m2!1sen!2sus"
          width="100%" height="100%" allowfullscreen="" title="Google Map showing directions to Tigris Mediterranean Grille"
          loading="lazy"></iframe>
      </div>


      <div class="mt-4 row d-flex justify-content-around text-center">

        <div class="col-sm-6 col-md-5 d-flex flex-column mb-4 mb-md-0">
          <h3 class="mb-3">HOURS OF OPERATION</h3>
          <div class="hours-list">
            <p><span class="day">Monday:</span> <span class="time ml-2">10 AM - 7 PM</span></p>
            <p><span class="day">Tuesday:</span> <span class="time ml-2">10 AM - 7 PM</span></p>
            <p><span class="day">Wednesday:</span> <span class="time ml-2">10 AM - 7 PM</span></p>
            <p><span class="day">Thursday:</span> <span class="time ml-2">10 AM - 7 PM</span></p>
            <p><span class="day">Friday:</span> <span class="time ml-2">10 AM - 7 PM</span></p>
            <p><span class="day">Saturday:</span> <span class="time ml-2">10 AM - 7 PM</span></p>
            <p><span class="day time--closed">Sunday:</span> <span class="time time--closed ml-2">Closed</span></p>
          </div>
        </div>

        <div class="col-sm-6 col-md-5 d-flex flex-column mb-4 mb-md-0">
          <h3 class="mb-3">LET'S CONNECT</h3>
          <div class="social-list">
            <a aria-label="Read our Google Reviews" class="social-list__item" href="{{google}}" target="_blank" rel="noopener">
              <i class="bi bi-google social-list__icon"></i>
              <span>Google</span>
              <i class="bi bi-arrow-right-short ms-auto"></i>
            </a>
            <a aria-label="View our Yelp page" class="social-list__item" href="{{yelp}}" target="_blank" rel="noopener">
              <i class="bi bi-yelp social-list__icon"></i>
              <span>Yelp!</span>
              <i class="bi bi-arrow-right-short ms-auto"></i>
            </a>
            <a aria-label="View our TikTok page" class="social-list__item" href="{{tiktok}}" target="_blank" rel="noopener">
              <i class="bi bi-tiktok social-list__icon"></i>
              <span>TikTok</span>
              <i class="bi bi-arrow-right-short ms-auto"></i>
            </a>
            <a aria-label="Follow us on Instagram" class="social-list__item" href="{{instagram}}" target="_blank" rel="noopener">
              <i class="bi bi-instagram social-list__icon"></i>
              <span>Instagram</span>
              <i class="bi bi-arrow-right-short ms-auto"></i>
            </a>
            <a aria-label="Follow us on Facebook" class="social-list__item" href="{{facebook}}" target="_blank" rel="noopener">
              <i class="bi bi-facebook social-list__icon"></i>
              <span>Facebook</span>
              <i class="bi bi-arrow-right-short ms-auto"></i>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
  
  {{!-- Alert Modal --}}
  {{> alert-modal}}
  
  {{!-- Footer --}}
  {{> footer}}
  
  {{!-- js --}}
  <script type="module" src="{{url}}assets/js/contact.js"></script>
</body>
